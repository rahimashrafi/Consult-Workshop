# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# LLM model to use. Default is Claude Sonnet 4.6 (good quality/cost balance).
# Full model list: https://openrouter.ai/models
# Examples: anthropic/claude-haiku-4.5  |  deepseek/deepseek-v3.2
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ── Behaviour (optional — safe to leave at defaults) ──────────────────────────

# How many hours back to look for new articles (default: 25, slightly over 24h
# to avoid missing items published near the daily boundary).
LOOKBACK_HOURS=25

# How many sources to randomly sample from the serendipity pool each run.
# Higher = broader coverage, slightly higher cost. Default: 3.
SERENDIPITY_N=3

# Minimum number of Tier 1 articles before the pipeline stops iterating.
# If fewer are found, the pipeline fetches more sources and re-scores
# (up to MAX_ITERATIONS times). Default: 3.
TIER1_THRESHOLD=3

# Maximum number of fetch-and-score iterations if Tier 1 count is low. Default: 3.
MAX_ITERATIONS=3

# Set to 'true' to include low-signal (Tier 3) articles in the briefing output.
# Useful for debugging or when you want full coverage. Default: false.
INCLUDE_TIER3=false

# ── RSSHub (optional — only needed for Twitter/X social monitoring) ────────────

# URL of your self-hosted RSSHub instance (no trailing slash).
# Required only if you add Twitter/X accounts to config/sources.yaml.
# See the README for setup instructions.
# RSSHUB_INSTANCE=https://your-rsshub-instance.railway.app

# Local output directory for generated briefings.
OUTPUT_DIR=outputs
